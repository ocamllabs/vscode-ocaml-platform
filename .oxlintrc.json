{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [".claude"],
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "plugins": [
    "eslint",
    "typescript",
    "unicorn",
    "react",
    "react-perf",
    "oxc",
    "import",
    "jsdoc",
    "jsx-a11y",
    "node",
    "promise"
  ],
  "rules": {
    "react/react-compiler": "error"
  }
}
